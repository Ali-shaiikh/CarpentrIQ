# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/carpentriq

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxx
RAZORPAY_KEY_SECRET=xxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxx

# Anthropic (claude-haiku-4-5 ONLY — see CLAUDE.md cost rules)
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxx
RESEND_FROM_EMAIL=noreply@carpentriq.in

# Storage (Supabase Storage or local path)
STORAGE_BUCKET=carpentriq-uploads
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=xxxxxx

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# OTP — Fast2SMS (no DLT registration required — sign up at fast2sms.com)
FAST2SMS_API_KEY=xxxxxx

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
REPLICATE_API_TOKEN=r8_your_token_here
